// DevelopmentSecrets.xcconfig.example - copy this to DevelopmentSecrets.xcconfig (gitignored)
// and fill in the seeded mobile key. The real file is never committed (build spec §12).
//
// 1. cd backend && npm run seed   (prints mobileKey; also written to backend/.seeded-keys.json)
// 2. cp ios-demo/DevelopmentSecrets.xcconfig.example ios-demo/DevelopmentSecrets.xcconfig
// 3. paste the mobileKey below, then regenerate the project if needed:
//    xcodegen generate --spec ios-demo/project.yml
//
// xcconfig values cannot contain "//", so the host has no scheme; the app builds http://<host>.
LIVESTAGE_API_KEY = ls_mobile_REPLACE_WITH_SEEDED_KEY
LIVESTAGE_API_HOST = localhost:8787
