# Portal local config. Copy to `.env.local` (gitignored) and fill in.
# All values are optional; the portal has working localhost defaults without this file.

# Backend base URL the portal calls (default: http://localhost:8787).
# VITE_API_BASE=http://localhost:8787

# Admin token for the /v1/admin routes (default: dev-admin-token, local-demo only).
# VITE_ADMIN_TOKEN=dev-admin-token

# A `service` key for the Insights API, so the Analytics dashboard works without
# clicking "Use this service key for the dashboard" in Projects & keys.
# Copy the service key from backend/.seeded-keys.json after running `npm run seed`.
# VITE_SERVICE_KEY=ls_service_xxxxxxxx.yyyyyyyy
